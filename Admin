<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TanışBul — Admin Panel</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.49.4/dist/umd/supabase.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --pink: #FF6B9D;
  --purple: #A855F7;
  --cyan: #06B6D4;
  --green: #10B981;
  --yellow: #FBBF24;
  --red: #EF4444;
  --orange: #F97316;
  --bg: #07070F;
  --surface: #0F0F1C;
  --card: #13131F;
  --border: rgba(255,255,255,0.06);
  --text: #F1F0F5;
  --muted: rgba(241,240,245,0.45);
  --sidebar-w: 240px;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; }

/* SIDEBAR */
.sidebar { width: var(--sidebar-w); min-height: 100vh; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }
.sidebar-logo { padding: 28px 24px 20px; border-bottom: 1px solid var(--border); }
.logo-text { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 800; background: linear-gradient(135deg, var(--pink), var(--purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.logo-sub { font-size: 11px; color: var(--muted); margin-top: 2px; letter-spacing: 0.08em; text-transform: uppercase; }
.sidebar-nav { flex: 1; padding: 16px 12px; display: flex; flex-direction: column; gap: 4px; overflow-y: auto; }
.nav-section-label { font-size: 10px; font-weight: 600; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; padding: 12px 12px 6px; }
.nav-link { display: flex; align-items: center; gap: 12px; padding: 10px 14px; border-radius: 12px; cursor: pointer; transition: all 0.2s; font-size: 14px; font-weight: 500; color: var(--muted); }
.nav-link:hover { background: rgba(255,255,255,0.04); color: var(--text); }
.nav-link.active { background: linear-gradient(135deg, rgba(255,107,157,0.15), rgba(168,85,247,0.15)); color: var(--text); border: 1px solid rgba(255,107,157,0.2); }
.nav-icon { font-size: 18px; opacity: 0.7; }
.nav-badge { margin-left: auto; background: var(--pink); color: white; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px; }
.nav-badge.green { background: var(--green); }
.sidebar-footer { padding: 16px 12px; border-top: 1px solid var(--border); }
.admin-user { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 12px; }
.admin-avatar { width: 36px; height: 36px; border-radius: 12px; background: linear-gradient(135deg, var(--pink), var(--purple)); display: flex; align-items: center; justify-content: center; font-size: 16px; }
.admin-name { font-size: 13px; font-weight: 600; }
.admin-role { font-size: 11px; color: var(--muted); }

/* MAIN */
.main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; }
.topbar { padding: 20px 32px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; background: var(--surface); position: sticky; top: 0; z-index: 50; }
.topbar-title { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700; }
.live-dot { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: var(--green); }
.live-dot::before { content: ''; width: 8px; height: 8px; background: var(--green); border-radius: 50%; animation: pulse 1.5s infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
.topbar-btn { width: 40px; height: 40px; border-radius: 12px; background: var(--card); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 18px; cursor: pointer; transition: all 0.2s; }
.topbar-btn:hover { border-color: rgba(168,85,247,0.4); }

/* CONTENT */
.content { padding: 32px; flex: 1; }
.page { display: none; }
.page.active { display: block; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* STATS */
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
.stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 22px; position: relative; overflow: hidden; transition: transform 0.2s; cursor: default; }
.stat-card:hover { transform: translateY(-3px); }
.stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
.stat-card.pink::before { background: linear-gradient(90deg, var(--pink), var(--purple)); }
.stat-card.cyan::before { background: linear-gradient(90deg, var(--cyan), var(--green)); }
.stat-card.yellow::before { background: linear-gradient(90deg, var(--yellow), var(--orange)); }
.stat-card.green::before { background: linear-gradient(90deg, var(--green), var(--cyan)); }
.stat-icon { width: 44px; height: 44px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 14px; }
.stat-icon.pink { background: rgba(255,107,157,0.15); }
.stat-icon.cyan { background: rgba(6,182,212,0.15); }
.stat-icon.yellow { background: rgba(251,191,36,0.15); }
.stat-icon.green { background: rgba(16,185,129,0.15); }
.stat-value { font-family: 'Syne', sans-serif; font-size: 32px; font-weight: 800; letter-spacing: -0.02em; }
.stat-label { font-size: 13px; color: var(--muted); margin-top: 4px; }
.stat-change { font-size: 12px; font-weight: 600; margin-top: 8px; }
.stat-change.up { color: var(--green); }

/* PANELS */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
.grid-3-1 { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 24px; }
.panel { background: var(--card); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; margin-bottom: 24px; }
.panel-header { padding: 20px 24px 16px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
.panel-title { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; }
.panel-action { font-size: 12px; color: var(--purple); cursor: pointer; font-weight: 600; }
.panel-action:hover { color: var(--pink); }

/* TABLE */
.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; }
thead th { padding: 12px 20px; text-align: left; font-size: 11px; font-weight: 600; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; border-bottom: 1px solid var(--border); }
tbody tr { border-bottom: 1px solid var(--border); transition: background 0.15s; cursor: pointer; }
tbody tr:hover { background: rgba(255,255,255,0.02); }
tbody tr:last-child { border-bottom: none; }
td { padding: 14px 20px; font-size: 13px; }
.user-cell { display: flex; align-items: center; gap: 12px; }
.u-avatar { width: 38px; height: 38px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; background: linear-gradient(135deg, rgba(255,107,157,0.15), rgba(168,85,247,0.15)); flex-shrink: 0; }
.u-name { font-weight: 600; font-size: 14px; }
.u-email { font-size: 12px; color: var(--muted); margin-top: 1px; }
.badge { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 8px; font-size: 11px; font-weight: 700; gap: 4px; }
.badge.active { background: rgba(16,185,129,0.15); color: var(--green); }
.badge.anon { background: rgba(168,85,247,0.15); color: #C084FC; }
.action-btns { display: flex; gap: 8px; }
.act-btn { width: 32px; height: 32px; border-radius: 10px; border: 1px solid var(--border); background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 14px; transition: all 0.2s; color: var(--muted); }
.act-btn:hover { background: rgba(255,255,255,0.06); color: var(--text); }

/* CHART */
.chart-wrap { padding: 20px 24px; }
.chart-bars { display: flex; align-items: flex-end; gap: 8px; height: 140px; }
.bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; }
.bar { width: 100%; border-radius: 8px 8px 0 0; cursor: pointer; transition: opacity 0.2s; }
.bar:hover { opacity: 0.8; }
.bar-label { font-size: 11px; color: var(--muted); }

/* MAP */
.map-container { height: 350px; border-radius: 16px; overflow: hidden; margin: 16px 24px 20px; position: relative; background: var(--surface); }
#map { width: 100%; height: 100%; }
.map-loading { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 8px; color: var(--muted); font-size: 13px; }

/* ACTIVITY */
.activity-list { padding: 8px 0; }
.activity-item { display: flex; align-items: center; gap: 14px; padding: 12px 24px; transition: background 0.2s; }
.activity-item:hover { background: rgba(255,255,255,0.02); }
.activity-dot { width: 36px; height: 36px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.activity-text { flex: 1; font-size: 13px; }
.activity-text strong { font-weight: 600; }
.activity-text span { color: var(--muted); }
.activity-time { font-size: 11px; color: var(--muted); white-space: nowrap; }

/* SECTION HEADER */
.section-hdr { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.section-hdr h2 { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800; }
.btn-primary { padding: 10px 20px; background: linear-gradient(135deg, var(--pink), var(--purple)); border: none; border-radius: 12px; color: white; font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 13px; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 14px rgba(255,107,157,0.3); }
.btn-primary:hover { transform: translateY(-2px); }

/* LOADING */
.loading { display: flex; align-items: center; justify-content: center; padding: 60px; color: var(--muted); gap: 12px; }
.spinner { width: 24px; height: 24px; border: 2px solid rgba(255,255,255,0.1); border-top-color: var(--pink); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* LOGIN */
.login-screen { min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 24px; }
.login-card { background: var(--card); border: 1px solid var(--border); border-radius: 24px; padding: 40px; width: 400px; display: flex; flex-direction: column; gap: 20px; }
.login-title { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800; background: linear-gradient(135deg, var(--pink), var(--purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-align: center; }
.input-field { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 14px 16px; font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--text); outline: none; width: 100%; transition: border-color 0.2s; }
.input-field:focus { border-color: var(--purple); }
.input-field::placeholder { color: var(--muted); }
.error-msg { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); border-radius: 12px; padding: 12px 16px; font-size: 13px; color: #FF8080; display: none; }
</style>
</head>
<body>

<div id="root">
  <div class="loading"><div class="spinner"></div> Yükleniyor...</div>
</div>

<script>
// ── Supabase ──
const SUPABASE_URL = 'https://snbqilkkysxmzmjfsihf.supabase.co';
const SUPABASE_KEY = 'sb_publishable_HJ2nnuGyTszm7q_2y40KDQ_GZrSUenq';
const { createClient } = supabase;
const db = createClient(SUPABASE_URL, SUPABASE_KEY);

// ── Admin password (simple protection) ──
const ADMIN_PASS = 'tanisbul2026';

let stats = { users: 0, messages: 0, friendships: 0 };
let allUsers = [];
let allMessages = [];
let activePage = 'dashboard';

// ── Check admin session ──
function isAdmin() { return localStorage.getItem('tb_admin') === 'true'; }

async function init() {
  if (!isAdmin()) { showLogin(); return; }
  await loadData();
  showAdmin();
}

async function loadData() {
  const [{ data: users }, { data: messages }, { data: friendships }] = await Promise.all([
    db.from('profiles').select('*').order('created_at', { ascending: false }),
    db.from('messages').select('*').order('created_at', { ascending: false }),
    db.from('friendships').select('*').order('created_at', { ascending: false })
  ]);
  allUsers = users || [];
  allMessages = messages || [];
  stats = {
    users: allUsers.length,
    messages: allMessages.length,
    friendships: (friendships || []).length
  };
}

// ── LOGIN ──
function showLogin() {
  document.getElementById('root').innerHTML = `
    <div class="login-screen">
      <div class="login-card">
        <div class="login-title">🎭 TanışBul Admin</div>
        <div style="color:var(--muted);font-size:13px;text-align:center;">Yönetici paneline erişmek için şifrenizi girin</div>
        <input class="input-field" id="passInput" type="password" placeholder="Admin şifresi" onkeydown="if(event.key==='Enter') login()">
        <div class="error-msg" id="loginError">❌ Hatalı şifre!</div>
        <button class="btn-primary" onclick="login()" style="padding:14px;">Giriş Yap</button>
      </div>
    </div>
  `;
}

function login() {
  const pass = document.getElementById('passInput').value;
  if (pass === ADMIN_PASS) {
    localStorage.setItem('tb_admin', 'true');
    loadData().then(showAdmin);
  } else {
    document.getElementById('loginError').style.display = 'block';
  }
}

// ── ADMIN LAYOUT ──
function showAdmin() {
  document.getElementById('root').innerHTML = `
    <aside class="sidebar">
      <div class="sidebar-logo">
        <div class="logo-text">TanışBul</div>
        <div class="logo-sub">Admin Paneli</div>
      </div>
      <nav class="sidebar-nav">
        <div class="nav-section-label">Genel</div>
        <div class="nav-link active" id="nav-dashboard" onclick="showPage('dashboard',this)">
          <span class="nav-icon">📊</span> Dashboard
        </div>
        <div class="nav-link" id="nav-users" onclick="showPage('users',this)">
          <span class="nav-icon">👥</span> Kullanıcılar
          <span class="nav-badge">${stats.users}</span>
        </div>
        <div class="nav-link" id="nav-messages" onclick="showPage('messages',this)">
          <span class="nav-icon">💬</span> Mesajlar
          <span class="nav-badge green">${stats.messages}</span>
        </div>
        <div class="nav-link" id="nav-map" onclick="showPage('map',this)">
          <span class="nav-icon">🗺️</span> Konum Haritası
        </div>
        <div class="nav-section-label">Sistem</div>
        <div class="nav-link" id="nav-settings" onclick="showPage('settings',this)">
          <span class="nav-icon">⚙️</span> Ayarlar
        </div>
      </nav>
      <div class="sidebar-footer">
        <div class="admin-user">
          <div class="admin-avatar">👨‍💼</div>
          <div>
            <div class="admin-name">Admin</div>
            <div class="admin-role">Süper Admin</div>
          </div>
          <span onclick="logout()" style="margin-left:auto;cursor:pointer;color:var(--muted);font-size:16px;" title="Çıkış">🚪</span>
        </div>
      </div>
    </aside>

    <main class="main">
      <div class="topbar">
        <div style="display:flex;align-items:center;gap:16px;">
          <div class="topbar-title" id="pageTitle">Dashboard</div>
          <div class="live-dot">Canlı</div>
        </div>
        <div style="display:flex;gap:10px;">
          <div class="topbar-btn" onclick="refreshData()" title="Yenile">🔄</div>
          <div class="topbar-btn">🔔</div>
        </div>
      </div>
      <div class="content" id="pageContent"></div>
    </main>
  `;
  renderPage('dashboard');
}

async function refreshData() {
  await loadData();
  renderPage(activePage);
}

function logout() {
  localStorage.removeItem('tb_admin');
  showLogin();
}

const pageTitles = {
  dashboard: 'Dashboard', users: 'Kullanıcılar',
  messages: 'Mesajlar', map: 'Konum Haritası', settings: 'Ayarlar'
};

function showPage(page, el) {
  activePage = page;
  document.querySelectorAll('.nav-link').forEach(n => n.classList.remove('active'));
  if (el) el.classList.add('active');
  document.getElementById('pageTitle').textContent = pageTitles[page] || page;
  renderPage(page);
}

function renderPage(page) {
  const content = document.getElementById('pageContent');
  if (!content) return;
  if (page === 'dashboard') content.innerHTML = renderDashboard();
  else if (page === 'users') content.innerHTML = renderUsers();
  else if (page === 'messages') content.innerHTML = renderMessages();
  else if (page === 'map') { content.innerHTML = renderMap(); initMap(); }
  else if (page === 'settings') content.innerHTML = renderSettings();
}

// ── DASHBOARD ──
function renderDashboard() {
  const today = new Date().toDateString();
  const todayUsers = allUsers.filter(u => new Date(u.created_at).toDateString() === today).length;
  const todayMsgs = allMessages.filter(m => new Date(m.created_at).toDateString() === today).length;
  const anonUsers = allUsers.filter(u => u.is_anon).length;

  // Weekly chart data (last 7 days)
  const days = ['Pzt','Sal','Çar','Per','Cum','Cmt','Paz'];
  const weekData = Array(7).fill(0);
  const now = new Date();
  allUsers.forEach(u => {
    const diff = Math.floor((now - new Date(u.created_at)) / (1000*60*60*24));
    if (diff < 7) weekData[6-diff]++;
  });
  const maxVal = Math.max(...weekData, 1);

  const barsHTML = weekData.map((val, i) => `
    <div class="bar-col">
      <div class="bar" style="height:${Math.max(8, (val/maxVal)*130)}px;background:${i===6?'linear-gradient(180deg,#06B6D4,#10B981)':'linear-gradient(180deg,#FF6B9D,#A855F7)'};"></div>
      <div class="bar-label">${days[i]}</div>
    </div>
  `).join('');

  const recentHTML = allUsers.slice(0, 5).map(u => `
    <div class="activity-item">
      <div class="activity-dot" style="background:rgba(255,107,157,0.15);">🎭</div>
      <div class="activity-text"><strong>${u.username || 'Anonim'}</strong> <span>kayıt oldu</span></div>
      <div class="activity-time">${timeAgo(u.created_at)}</div>
    </div>
  `).join('') || '<div class="loading" style="padding:20px;">Henüz kullanıcı yok</div>';

  return `
    <div class="section-hdr"><h2>Genel Bakış</h2><span style="color:var(--muted);font-size:13px;">${new Date().toLocaleDateString('tr-TR', {day:'numeric',month:'long',year:'numeric'})}</span></div>

    <div class="stats-grid">
      <div class="stat-card pink">
        <div class="stat-icon pink">👥</div>
        <div class="stat-value">${stats.users}</div>
        <div class="stat-label">Toplam Kullanıcı</div>
        <div class="stat-change up">↑ +${todayUsers} bugün</div>
      </div>
      <div class="stat-card cyan">
        <div class="stat-icon cyan">💬</div>
        <div class="stat-value">${stats.messages}</div>
        <div class="stat-label">Toplam Mesaj</div>
        <div class="stat-change up">↑ +${todayMsgs} bugün</div>
      </div>
      <div class="stat-card yellow">
        <div class="stat-icon yellow">💞</div>
        <div class="stat-value">${stats.friendships}</div>
        <div class="stat-label">Arkadaşlık</div>
        <div class="stat-change up">Toplam bağlantı</div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon green">🎭</div>
        <div class="stat-value">${anonUsers}</div>
        <div class="stat-label">Anonim Kullanıcı</div>
        <div class="stat-change up">${stats.users > 0 ? Math.round(anonUsers/stats.users*100) : 0}% anonim mod</div>
      </div>
    </div>

    <div class="grid-3-1">
      <div class="panel">
        <div class="panel-header"><div class="panel-title">📈 Haftalık Kayıt</div></div>
        <div class="chart-wrap"><div class="chart-bars">${barsHTML}</div></div>
      </div>
      <div class="panel">
        <div class="panel-header"><div class="panel-title">⚡ Son Aktivite</div></div>
        <div class="activity-list">${recentHTML}</div>
      </div>
    </div>
  `;
}

// ── USERS ──
function renderUsers() {
  const rowsHTML = allUsers.length === 0
    ? `<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--muted);">Henüz kullanıcı yok</td></tr>`
    : allUsers.map(u => `
      <tr>
        <td><div class="user-cell">
          <div class="u-avatar">${u.avatar || '🎭'}</div>
          <div><div class="u-name">${u.username || 'Anonim'}</div><div class="u-email">${u.email || ''}</div></div>
        </div></td>
        <td>${u.city || '—'}</td>
        <td>${u.age || '—'}</td>
        <td>${timeAgo(u.created_at)}</td>
        <td>
          ${u.is_anon ? '<span class="badge anon">🎭 Anonim</span>' : '<span class="badge active">● Açık</span>'}
        </td>
        <td><div class="action-btns">
          <button class="act-btn" title="Sil" onclick="deleteUser('${u.id}')">🗑️</button>
        </div></td>
      </tr>`).join('');

  return `
    <div class="section-hdr"><h2>👥 Kullanıcılar</h2><span style="color:var(--muted);">${allUsers.length} toplam kullanıcı</span></div>
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">Tüm Kullanıcılar</div>
        <div class="panel-action" onclick="refreshData()">🔄 Yenile</div>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Kullanıcı</th><th>Şehir</th><th>Yaş</th><th>Kayıt</th><th>Mod</th><th>İşlem</th></tr></thead>
          <tbody>${rowsHTML}</tbody>
        </table>
      </div>
    </div>
  `;
}

async function deleteUser(id) {
  if (!confirm('Bu kullanıcıyı silmek istediğine emin misin?')) return;
  await db.from('messages').delete().or(`sender_id.eq.${id},receiver_id.eq.${id}`);
  await db.from('friendships').delete().or(`sender_id.eq.${id},receiver_id.eq.${id}`);
  await db.from('profiles').delete().eq('id', id);
  await refreshData();
}

// ── MESSAGES ──
function renderMessages() {
  const rowsHTML = allMessages.slice(0, 50).length === 0
    ? `<tr><td colspan="4" style="text-align:center;padding:40px;color:var(--muted);">Henüz mesaj yok</td></tr>`
    : allMessages.slice(0, 50).map(m => {
        const sender = allUsers.find(u => u.id === m.sender_id);
        const receiver = allUsers.find(u => u.id === m.receiver_id);
        return `
          <tr>
            <td>${sender?.username || '—'}</td>
            <td>${receiver?.username || '—'}</td>
            <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${m.content}</td>
            <td>${timeAgo(m.created_at)}</td>
          </tr>`;
      }).join('');

  return `
    <div class="section-hdr"><h2>💬 Mesajlar</h2><span style="color:var(--muted);">${allMessages.length} toplam mesaj</span></div>
    <div class="panel">
      <div class="panel-header"><div class="panel-title">Son Mesajlar</div></div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Gönderen</th><th>Alıcı</th><th>Mesaj</th><th>Zaman</th></tr></thead>
          <tbody>${rowsHTML}</tbody>
        </table>
      </div>
    </div>
  `;
}

