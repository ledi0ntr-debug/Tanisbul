        <div id="map"></div>
        <div class="map-loading" id="mapLoading"><div class="spinner"></div> Harita yükleniyor...</div>
      </div>
    </div>
    <div class="panel">
      <div class="panel-header"><div class="panel-title">📍 Şehir Dağılımı</div></div>
      <div style="padding:20px 24px;">
        ${getCityStats()}
      </div>
    </div>
  `;
}

function getCityStats() {
  const cities = {};
  allUsers.forEach(u => { if (u.city) cities[u.city] = (cities[u.city]||0)+1; });
  const sorted = Object.entries(cities).sort((a,b) => b[1]-a[1]).slice(0,10);
  if (sorted.length === 0) return '<div style="color:var(--muted);font-size:13px;">Henüz konum verisi yok</div>';
  const max = sorted[0][1];
  return sorted.map(([city, count]) => `
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
      <div style="font-size:13px;font-weight:600;width:120px;">📍 ${city}</div>
      <div style="flex:1;background:rgba(255,255,255,0.05);border-radius:8px;height:8px;overflow:hidden;">
        <div style="height:100%;width:${(count/max)*100}%;background:linear-gradient(90deg,#FF6B9D,#A855F7);border-radius:8px;"></div>
      </div>
      <div style="font-size:13px;color:var(--muted);width:30px;text-align:right;">${count}</div>
    </div>
  `).join('');
}

function initMap() {
  const usersWithLocation = allUsers.filter(u => u.lat && u.lng);
  document.getElementById('mapLoading').style.display = 'none';

  // Simple SVG map with dots
  const mapEl = document.getElementById('map');
  if (usersWithLocation.length === 0) {
    mapEl.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--muted);font-size:13px;flex-direction:column;gap:8px;"><div style="font-size:48px;">🗺️</div><div>Henüz konum verisi yok</div></div>`;
    return;
  }

  // Use OpenStreetMap iframe
  const center = usersWithLocation[0];
  mapEl.innerHTML = `<iframe 
    width="100%" height="100%" 
    src="https://www.openstreetmap.org/export/embed.html?bbox=25,36,45,42&layer=mapnik&marker=${center.lat},${center.lng}" 
    style="border:none;border-radius:16px;">
  </iframe>`;
}

